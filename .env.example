# ── Base de datos (Neon PostgreSQL — solo en producción) ──────────────────────
# Obtener en https://console.neon.tech → tu proyecto → Connection string
DATABASE_URL=postgresql://usuario:password@host.neon.tech/neondb?sslmode=require

# ── Panel Admin ───────────────────────────────────────────────────────────────
# Contraseña para acceder a /admin
ADMIN_PASSWORD=tu_password_seguro

# ── URL pública (para links en emails) ───────────────────────────────────────
# Tu dominio de Vercel (ej: https://imperial-tienda.vercel.app)
NEXT_PUBLIC_URL=https://tu-proyecto.vercel.app

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtener en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Dominio verificado en Resend (o usa onboarding@resend.dev para pruebas)
RESEND_FROM=Imperial <no-reply@tudominio.com>
